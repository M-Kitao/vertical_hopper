        <joint axis="0 -1 0" stiffness="0" damping="0" armature="0.2" limited="true" range="-90 90" name="left_ankle_joint" pos="0 0 0" type="hinge"/>
        <site name="s_left_ankle" pos="0 0 0" size="0.011"/> 
        <geom friction="1.0 0.005 0.0001" name="left_heel_geom" type="cylinder" size="0.02" fromto="-0.02 -0.05 -0.04 -0.02 0.05 -0.04" mass="0.2" rgba="0.95 0.6 .4 1"/> -->
        <!-- <geom friction="1.0 0.005 0.0001" name="left_foot_geom" type="box" pos="0.045 0 -0.04" size="0.065 0.05 0.02" mass="0.8" rgba="0.95 0.6 .4 1" solimp="0.8 0.95 0.01 0.5 2" solref="0.01 1.0"/> -->
        <!-- <geom friction="1.0 0.005 0.0001" name="left_foot_geom" type="box" pos="0.07125 0 -0.04" size="0.09125 0.05 0.02" mass="1.25" rgba="0.95 0.6 .4 1" solimp="0. 0.99 0.01 0.01 2" solref="0.01 1.0"/>
        <site name="s_left_toe" pos="0.1625 0 -0.06" size="0.011"/> -->

        <!-- <body name="left_toe" pos="0.11 0 -0.05">
        <site name="s_left_toe" pos="0.0525 0 0" size="0.011"/>
        <geom friction="1.0 0.005 0.0001" name="left_toe_geom" type="box" pos="0.02625 0 0" size="0.02625 0.05 0.01" mass="0.25" rgba="0.95 0.6 .4 1" solimp="0. 0.99 0.01 0.01 2" solref="0.01 1.0"/>
        <joint axis="0 -1 0" stiffness="30" damping="0" armature="0.2" limited="true" range="0 1" name="left_toe_joint" pos="0 0 -0.01" type="hinge"/>

        </body> 
        </body>
        </body>
        </body> -->

    </body>
  </worldbody>


  <!--"geer" here is the maximum output of the actuator-->
  <actuator>
    <!-- <motor name="torso_joint"       gear="200"  joint="torso_joint"/> -->
    <motor name="hip_joint"         gear="200"  joint="hip_joint"/>
    <motor name="knee_joint"        gear="200"  joint="knee_joint"/>
    <!-- <motor name="ankle_joint"       gear="200"  joint="ankle_joint"/>
    <motor name="left_hip_joint"    gear="200"  joint="left_hip_joint"/>
    <motor name="left_knee_joint"   gear="200"  joint="left_knee_joint"/>
    <motor name="left_ankle_joint"  gear="200"  joint="left_ankle_joint"/> -->
