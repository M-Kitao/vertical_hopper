<mujoco model="vertcal_hopper">
  <compiler angle="degree" coordinate="local"/>
  <!--compiler>
  <lengthrange mode='none'/>
  </compiler-->
  <default>
    <joint armature="0.01" damping="1" limited="true"/>
    <!-- contact impedance can be changed through adjusting solimp -->
    <!-- timeconst is very very very very important!!!!!!!!!!!!!!!!!!!!!!!! -->
    <!-- <geom conaffinity="0" condim="3" contype="1" density="1000" friction="1.0 0.1 0.1" rgba="0.8 0.6 .4 1" solimp="0. 0.99 0.025 0.01 2" solref="0.25 5.0"/> -->
    <geom conaffinity="0" condim="3" contype="1" density="1000" friction="1.0 0.1 0.1" rgba="0.8 0.6 .4 1" solimp="0. 0.99 0.025 0.01 2" solref="0.15 5.0"/>
  </default>
  <option integrator="Euler" timestep="0.001250"/>
  <asset>
        <texture builtin="gradient" height="100" rgb1="1 1 1" rgb2="0 0 0" type="skybox" width="100"/>
        <texture builtin="flat" height="1278" mark="cross" markrgb="1 1 1" name="texgeom" random="0.01" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" type="cube" width="127"/>
        <texture builtin="checker" height="100" name="texplane" rgb1="0 0 0" rgb2="0.8 0.8 0.8" type="2d" width="100"/>
        <material name="MatPlane" reflectance="0.5" shininess="1" specular="1" texrepeat="480 1.5" texture="texplane"/>
        <material name="geom" texture="texgeom" texuniform="true"/>
  </asset>
  <worldbody>
    <light cutoff="30" diffuse="1 1 1" dir="-0 0 -1.3" directional="true" exponent="1" pos="0 0 1.3" specular=".1 .1 .1"/>
