<mujoco model="vertcal_hopper">
  <compiler angle="radian"/>

  <option timestep="0.00125"/>

  <default>
    <joint limited="true" armature="0.01" damping="1"/>
    <geom conaffinity="0" friction="1 0.1 0.1" solref="0.15 5" solimp="0 0.99 0.025 0.01" rgba="0.8 0.6 0.4 1"/>
  </default>

  <asset>
    <texture type="skybox" colorspace="auto" builtin="gradient" rgb1="1 1 1" rgb2="0 0 0" width="100" height="600"/>
    <texture type="cube" colorspace="auto" name="texgeom" builtin="flat" mark="cross" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" markrgb="1 1 1" width="127" height="762"/>
    <texture type="2d" colorspace="auto" name="texplane" builtin="checker" rgb1="0 0 0" rgb2="0.8 0.8 0.8" width="100" height="100"/>
    <material name="MatPlane" texture="texplane" texrepeat="480 1.5" specular="1" shininess="1" reflectance="0.5"/>
    <material name="geom" texture="texgeom" texuniform="true"/>
  </asset>

  <worldbody>
    <geom name="floor2" size="120 0.5 40" type="plane" conaffinity="1" material="MatPlane" rgba="0.8 0.9 0.8 1"/>
    <light pos="0 0 1.3" dir="0 0 -1" type="directional" cutoff="30" exponent="1" diffuse="1 1 1" specular="0.1 0.1 0.1"/>
    <body name="camera" pos="0 -3 0">
      <joint name="camerax" pos="0 0 0" axis="1 0 0" type="slide" limited="false" armature="0" damping="0"/>
      <geom name="camera_geom" size="0.05" pos="-0.3 0 0" friction="0.9" mass="1e-06" rgba="0.5 0.5 0.5 1"/>
      <camera name="track" pos="0 0 0.765" quat="0.707107 0.707107 0 0" mode="trackcom"/>
    </body>
    <body name="center" pos="0 0 0.965">
      <joint name="rootz" pos="0 0 0" axis="0 0 1" type="slide" limited="false" armature="0" damping="0"/>
      <geom name="center_geom" size="0.001" mass="0.1"/>
      <site name="s_hip" pos="0 0 0"/>
      <camera name="track2" pos="0 -2.8 -0.2" quat="0.707107 0.707107 0 0" mode="trackcom"/>
      <body name="hat1">
        <geom name="hat_geom" size="0.05 0.05 0.4" pos="0 0 0.4" type="box" mass="53.5" rgba="0.6 0.5 0.3 1"/>
        <geom name="hip_geom" size="0.06 0.06" quat="0.707107 0.707107 0 0" type="cylinder" mass="0" rgba="0.8 0.5 0.3 1"/>
      </body>
      <body name="thigh">
        <joint name="hip_joint" pos="0 0 0" axis="0 -1 0" range="-1.5708 1.5708" armature="0.2" damping="0"/>
        <geom name="thigh_geom" size="0.045 0.045 0.25" pos="0 0 -0.25" type="box" mass="17"/>
        <geom name="knee_geom" size="0.055 0.045" pos="0 0 -0.5" quat="0.707107 0.707107 0 0" type="cylinder" group="1" mass="0"/>
        <body name="shank" pos="0 0 -0.5">
          <joint name="knee_joint" pos="0 0 0" axis="0 -1 0" range="-2.35619 0" armature="0.2" damping="0"/>
          <geom name="shank_geom" size="0.03 0.03 0.21" pos="0 0 -0.225" type="box" mass="3.5"/>
          <site name="s_knee" pos="0 0 0"/>
          <body name="foot" pos="0 0 -0.4">
            <joint name="ankle_joint" pos="0 0 0" axis="0 -1 0" range="-1.5708 1.5708" armature="0.2" damping="0"/>
            <geom name="right_heel_geom" size="0.02 0.05" pos="-0.02 0 -0.04" quat="0.707107 0.707107 0 0" type="cylinder" friction="1 0.005 0.0001" mass="0.2"/>
            <geom name="right_foot_geom" size="0.09125 0.05 0.02" pos="0.07125 0 -0.04" type="box" friction="1 0.005 0.0001" solref="0.01 1" solimp="0 0.99 0.01" mass="1.25"/>
            <site name="s_ankle" pos="0 0 0" size="0.011"/>
            <site name="s_toe" pos="0.1625 0 -0.06" size="0.011"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <general name="hip_joint" joint="hip_joint" ctrlrange="-5 60" biastype="affine" gainprm="500" biasprm="0 -500 -0.01"/>
    <general name="knee_joint" joint="knee_joint" ctrlrange="-60 0" biastype="affine" gainprm="500" biasprm="0 -500 -0.01"/>
  </actuator>

  <sensor>
    <force site="s_ankle" name="heel_grf"/>
    <force site="s_toe" name="foot_grf"/>
    <touch site="s_hip" name="hip_touch_sensor"/>
    <touch site="s_knee" name="knee_touch_sensor"/>
    <touch site="s_toe" name="toe_touch_sensor"/>
  </sensor>
</mujoco>
